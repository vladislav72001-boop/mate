PORT=5012
CLIENT_ORIGIN=http://localhost:5011
APP_URL=http://localhost:5011
JWT_SECRET=change-this-in-production

# PostgreSQL (required). On Railway: use the Postgres plugin DATABASE_URL.
DATABASE_URL=postgresql://mate:mate@localhost:5432/mate?schema=public

# --- Email ---
# Preferred on Railway: Resend (HTTPS). GoDaddy SMTP usually times out (ETIMEDOUT CONN).
EMAIL_PROVIDER=resend
RESEND_API_KEY=
# Verify matedelivery.com in Resend dashboard, then:
MAIL_FROM="MATE <noreply@matedelivery.com>"
# Dev fallback before domain verify: MATE <onboarding@resend.dev>
#
# Optional SMTP (local / non-cloud only — often blocked from Railway):
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtpout.secureserver.net
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
# Required in production so email images/buttons point to your domain
# APP_URL=https://matedelivery.com
# MAIL_ASSET_URL=https://matedelivery.com
# MAIL_DISABLE=true
# MAIL_INLINE_IMAGES=false
# DEFAULT_EMAIL_REPLY_TO=info@matedelivery.com

# --- Stripe (required for card payments) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:5011/?payment=success
STRIPE_CANCEL_URL=http://localhost:5011/?payment=cancel
# Optional overrides for B2C send flow only:
# STRIPE_B2C_SUCCESS_URL=http://localhost:5011/?payment=success&flow=b2c
# STRIPE_B2C_CANCEL_URL=http://localhost:5011/?payment=cancel&flow=b2c

# --- Nova Post international (api.novapost.com) ---
NOVAPOST_API_KEY=
NOVAPOST_API_BASE_URL=https://api.novapost.com/v.1.0
# Windows: Node fetch may get 403 from NP WAF — PowerShell bridge (default on win32)
NOVAPOST_USE_POWERSHELL=true
# On API error, public-calculate returns mock price (legacy Strapi flag; mate-final uses circuit breaker)
# NOVAPOST_FALLBACK_MOCK=false
# Dev: skip real NP calls (mock calc + mock shipment on checkout)
# NOVAPOST_MOCK=true
# POST /shipments dimension caps (mm) for Sender API key — default 600 per side
# NOVAPOST_MAX_LENGTH_MM=600
# NOVAPOST_MAX_WIDTH_MM=600
# NOVAPOST_MAX_HEIGHT_MM=600
# Max actual weight per parcel for Sender API key (kg) — verified against live API
NOVAPOST_MAX_WEIGHT_KG=20

# --- Nova Post UA (Internet Document / TTN after payment, legacy Strapi) ---
NOVA_POSHTA_API_KEY=
NOVA_POSHTA_API_URL=https://api.novaposhta.ua/v2.0/json/
# Warehouse Ref UUIDs (required for B2C checkout unless sent in request body)
NOVA_POSHTA_SENDER_WAREHOUSE_REF=
NOVA_POSHTA_RECIPIENT_WAREHOUSE_REF=
# Set true to skip real NP UA calls in dev (mock TTN)
# NOVA_POSHTA_MOCK=true

# Client prices: mate = admin matrix (без НДС) + VAT; novapost = live NP API + VAT
# Matrix should mirror Nova Post net tariffs / Excel sheet values; VAT is added in settings.
PRICING_PREFER=mate
# After NP API errors, retry real NP after this many ms (default 60000)
# NOVAPOST_CIRCUIT_MS=60000
B2C_FRAGILE_FEE_EUR=1.98
B2C_INSURANCE_PERCENT=1
B2C_AMOUNT_TOLERANCE_PERCENT=3

# Dev only: allow fake Google/Apple login without OAuth (never enable in production)
# SOCIAL_AUTH_STUB=true

# Google Sign-In (OAuth 2.0 Web client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Same Client ID for Vite frontend (baked in at build time)
VITE_GOOGLE_CLIENT_ID=

# Sign in with Apple (Services ID = APPLE_CLIENT_ID)
APPLE_CLIENT_ID=com.matedelivery.web
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Full .p8 contents including BEGIN/END lines; use \n for newlines in Railway if needed
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=https://www.matedelivery.com/api/auth/apple/callback

# Force re-import pricing/settings from server/data/*.json on boot (overwrites admin edits)
# PRICING_SYNC_FROM_JSON=true
