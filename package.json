{
  "name": "mate-final",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.mjs",
    "build": "vite build",
    "start": "node server/index.mjs",
    "start:server": "node server/index.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:import": "node server/scripts/migrate-json-to-pg.mjs",
    "postinstall": "prisma generate || true"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@react-oauth/google": "^0.13.5",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "google-auth-library": "^10.9.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "libphonenumber-js": "^1.13.9",
    "nodemailer": "^7.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^22.3.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.0",
    "oxlint": "^1.71.0",
    "prisma": "^6.19.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
